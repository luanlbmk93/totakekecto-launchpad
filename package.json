{
  "name": "MEME2FUN-launchpad",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "concurrently -k \"npm run server\" \"npm run dev\" --names api,vite --prefix-colors blue,green",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "compile": "npx hardhat compile",
    "export:abi": "node server/export-abi.mjs",
    "deploy": "npx hardhat run contracts/deploy-full.cjs --network bnb_testnet",
    "deploy:bsc": "npx hardhat run contracts/deploy-full.cjs --network bsc",
    "deploy:testnet": "npx hardhat run contracts/deploy-full.cjs --network bnb_testnet",
    "verify:bsc": "npx hardhat run contracts/verify-all.cjs --network bsc",
    "verify:testnet": "npx hardhat run contracts/verify-all.cjs --network bnb_testnet",
    "start": "serve -s dist -l $PORT",
    "start:api": "node server/index.mjs",
    "server": "node server/index.mjs",
    "publish:backend": "powershell -ExecutionPolicy Bypass -File ./scripts/publish-backend.ps1"
  },
  "dependencies": {
    "@plasmicapp/loader-react": "^1.0.396",
    "@plasmicapp/react-web": "^0.2.399",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.99.2",
    "@web3-react/core": "^6.1.9",
    "@web3-react/injected-connector": "^6.0.7",
    "axios": "^1.7.7",
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "ethers": "^6.15.0",
    "express": "^5.2.1",
    "lightweight-charts": "^5.0.8",
    "lucide-react": "^0.344.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "recharts": "^3.1.2",
    "serve": "^14.2.5",
    "tailwind-scrollbar-hide": "^4.0.0",
    "viem": "^2.48.1",
    "wagmi": "^2.19.5",
    "web3": "^4.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@nomicfoundation/hardhat-toolbox": "^6.1.0",
    "@openzeppelin/contracts": "^5.6.1",
    "@openzeppelin/contracts-upgradeable": "^5.6.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "concurrently": "^9.1.2",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "hardhat": "^2.22.15",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
